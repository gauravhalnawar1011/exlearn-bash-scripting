pipeline {

    agent any

    environment {

        ACCOUNT_ID = '074095961179'
        REGION     = 'ap-south-1'
        IMAGE_NAME = 'student-app'
        ENVIRONMENT = 'dev'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Generate Image Tag') {
            steps {
                script {

                    COMMIT_ID = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()

                    IMAGE_TAG = "${ENVIRONMENT}-${IMAGE_NAME}-${COMMIT_ID}"

                    env.COMMIT_ID = COMMIT_ID
                    env.IMAGE_TAG = IMAGE_TAG

                    echo "Commit ID: ${COMMIT_ID}"
                    echo "Image Tag : ${IMAGE_TAG}"
                }
            }
        }

        stage('Login to ECR') {
            steps {
                sh '''
                aws ecr get-login-password \
                --region $REGION | \
                docker login \
                --username AWS \
                --password-stdin \
                $ACCOUNT_ID.dkr.ecr.$REGION.amazonaws.com
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
        docker build \
        -t $IMAGE_NAME:$IMAGE_TAG \
        ./jenkins-pipeline/getting-started-app
        '''
            }
        }

        stage('Tag Docker Image') {
            steps {
                sh '''
                docker tag \
                $IMAGE_NAME:$IMAGE_TAG \
                $ACCOUNT_ID.dkr.ecr.$REGION.amazonaws.com/$IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }

        stage('Push Image to ECR') {
            steps {
                sh '''
                docker push \
                $ACCOUNT_ID.dkr.ecr.$REGION.amazonaws.com/$IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }
    }

    post {

        success {
            echo "Image Push Successful"
            echo "Image URI:"
            echo "${ACCOUNT_ID}.dkr.ecr.${REGION}.amazonaws.com/${IMAGE_NAME}:${IMAGE_TAG}"
        }

        failure {
            echo "Pipeline Failed"
        }
    }
}
